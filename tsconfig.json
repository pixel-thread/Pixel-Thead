{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@db/*": ["./src/shared/db/*"],
      "@types/*": ["./src/shared/types/*"],
      "@utils/*": ["./src/shared/utils/*"],
      "@middleware/*": ["./src/shared/middleware/*"],
      "@config/*": ["./src/shared/config/*"],
      "@app/*": ["./src/app/*"],
      "@features/*": ["./src/features/*"]
    },
    "types": ["node"],
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    ".next/types/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
