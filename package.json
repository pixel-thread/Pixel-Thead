{
  "name": "pixel-thread",
  "version": "1.1.0",
  "description": "Central Payments & Auth Service — Hono · Razorpay · Clerk · Prisma",
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "pnpm db:generate && tsc",
    "build:dist": "pnpm db:generate && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@prisma/client --external:@hono/node-server && pnpm postbuild:dist",
    "postbuild:dist": "mkdir -p dist/public && cp package.json vercel.json dist/ && cp -r prisma dist/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "db:generate": "pnpm dlx prisma generate",
    "db:migrate:dev": "pnpm dlx prisma migrate dev",
    "db:migrate:deploy": "pnpm dlx prisma migrate deploy",
    "db:studio": "pnpm dlx prisma studio",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:reset": "pnpm dlx prisma migrate reset"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "@clerk/hono": "^0.1.15",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.7.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.25.0",
    "hono": "^4.12.14",
    "pg": "^8.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.0.0"
  }
}
