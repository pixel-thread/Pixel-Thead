{
  "name": "pixel-thread",
  "version": "1.1.0",
  "description": "Central Payments & Auth Service — Hono · Razorpay · Clerk · Prisma",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint src",
    "lint:fix": "next lint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "db:generate": "pnpm dlx prisma generate",
    "db:migrate:dev": "pnpm dlx prisma migrate dev",
    "db:migrate:deploy": "pnpm dlx prisma migrate deploy",
    "db:studio": "pnpm dlx prisma studio",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:reset": "pnpm dlx prisma migrate reset"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "@clerk/nextjs": "^7.2.3",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.1",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.3.0",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.0.0"
  }
}
