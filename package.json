{
  "name": "pixel-thread",
  "version": "1.1.0",
  "description": "Central Payments & Auth Service — Hono · Razorpay · Clerk · Prisma",
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "db:generate": "pnpm dlx prisma generate",
    "db:migrate:dev": "pnpm dlx prisma migrate dev",
    "db:migrate:deploy": "pnpm dlx prisma migrate deploy",
    "db:studio": "pnpm dlx prisma studio",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:reset": "pnpm dlx prisma migrate reset"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/hono": "^0.1.15",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^1.0.0"
  }
}